{
    // Enable linting on save and set the provider
    "editor.codeActionsOnSave": {
        "source.fixAll.flake8": "explicit"
    },
    "python.linting.enabled": true,
    "python.linting.flake8.enabled": true,
    "python.linting.lintOnSave": true,

    // Use Flake8 installed in the current environment
    "flake8.importStrategy": "fromEnvironment",

    // Optional: Pass arguments to Flake8 for customization
    "flake8.args": [
        "--max-line-length=79",
        // "--ignore=E203,E402,W503"
    ],
    "black-formatter.args": [
        "--line-length=79"
    ],

    // Optional: Default formatter (Black is a common choice)
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "files.insertFinalNewline": true,
        "editor.rulers": [79],
        "editor.tabSize": 4
    }
}
